# GitHub Actions CI starter for this template.
#
# Usage:
#   1. Copy this file to .github/workflows/ci.yml (drop the .example extension).
#   2. Uncomment the toolchain block(s) that match your stack.
#   3. Replace the "Run tests" step with the exact command from
#      docs/wiki/commands.md under "## Test".
#   4. Commit on a feat/chore branch; the workflow runs on push and PR.
#
# This file is intentionally not active (`.example` suffix). The template
# can't guess your stack — /project:interview plus a /project:work cycle
# (driven by the developer agent) should set up the real ci.yml once the
# stack is known.
#
# ----------------------------------------------------------------------
# Jobs in this workflow and what they enforce:
#
#   test         — Runs the project's test suite (replace placeholder with
#                  the command from docs/wiki/commands.md).
#
#   wiki-drift   — Enforces behavioral rule 1 ("wiki travels with code") on
#                  the server. Computes the diff against the PR's merge-base
#                  with origin/main and fails the job if a PR modifies code
#                  without touching any docs/wiki/ page.
#
#   Note: test-first (behavioral rule 2) is intentionally not enforced here.
#   It is a discipline the agent keeps during interactive work on feat/* and
#   fix/* branches, not a gate that can be checked server-side.
# ----------------------------------------------------------------------

name: CI

on:
  push:
    branches: [main]
  pull_request:

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      # ---------- Toolchain — uncomment the block(s) you need ----------

      # Python:
      # - uses: actions/setup-python@v5
      #   with:
      #     python-version: "3.x"
      # - run: pip install -e .[dev]
      #   # or: pip install -r requirements.txt

      # Node / TypeScript:
      # - uses: actions/setup-node@v4
      #   with:
      #     node-version: "20"
      #     cache: npm
      # - run: npm ci

      # Go:
      # - uses: actions/setup-go@v5
      #   with:
      #     go-version: stable
      #     cache: true

      # Rust:
      # - uses: dtolnay/rust-toolchain@stable
      # - uses: Swatinem/rust-cache@v2

      # ---------- Lint (optional but recommended) ----------
      # - name: Lint
      #   run: |
      #     # replace with the command from docs/wiki/commands.md#lint
      #     echo "no lint configured" && exit 0

      # ---------- Tests ----------
      - name: Run tests
        run: |
          # Replace with the command from docs/wiki/commands.md#test.
          # Example: pytest -q   |   npm test   |   go test ./...   |   cargo test
          echo "TODO: wire up test command from docs/wiki/commands.md" >&2
          exit 1

  wiki-drift:
    # Enforces behavioral rule 1: code changes must be accompanied by a wiki
    # update. Computes the diff against the PR's merge-base with origin/main.
    runs-on: ubuntu-latest
    if: github.event_name == 'pull_request'
    steps:
      - uses: actions/checkout@v4
        with:
          # Need full history so we can compute merge-base with the PR base.
          fetch-depth: 0

      - name: Check wiki drift
        run: |
          set -uo pipefail
          base_ref="origin/${{ github.base_ref }}"
          git fetch origin "${{ github.base_ref }}" --depth=0 || true
          base_sha=$(git merge-base "$base_ref" HEAD 2>/dev/null || echo "")
          if [ -z "$base_sha" ]; then
            echo "[wiki-drift] could not compute merge-base with $base_ref; skipping" >&2
            exit 0
          fi

          files=$(git diff --name-only "$base_sha"..HEAD | sort -u | grep -v '^$' || true)
          if [ -z "$files" ]; then
            echo "[wiki-drift] no changed files; nothing to check" >&2
            exit 0
          fi

          code_touched=false
          wiki_touched=false
          while IFS= read -r f; do
            case "$f" in
              # Bookkeeping files don't count as a substantive wiki update.
              docs/wiki/log.md|docs/wiki/wiki-todos.md) : ;;
              docs/wiki/*) wiki_touched=true ;;
              src/*|app/*|lib/*|tests/*|test/*|cmd/*|internal/*|pkg/*) code_touched=true ;;
              *.py|*.js|*.ts|*.jsx|*.tsx|*.go|*.rs|*.java|*.rb|*.php|*.cs|*.kt|*.swift)
                code_touched=true
                ;;
            esac
          done <<< "$files"

          if $code_touched && ! $wiki_touched; then
            echo "[wiki-drift] FAIL: code modified in this PR but no docs/wiki/ page touched." >&2
            echo "" >&2
            echo "The wiki must travel with the code (behavioral rule 1)." >&2
            echo "Update the relevant docs/wiki/entities/<slug>.md and re-push." >&2
            exit 1
          fi

          echo "[wiki-drift] OK" >&2

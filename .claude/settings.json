{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Agent"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/test-first-check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-format.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/raw-index-sync.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/code-ref-check.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/wiki-drift-check.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/raw-pending-check.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/on-task-complete.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/auto-checkpoint.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  }
}

{
  "_comment": "Wiki-driven methodology hooks. Copy .claude/settings.local.json.template to .claude/settings.local.json to unlock Write/Edit/Bash.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-format.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/raw-index-sync.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/wiki-drift-check.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/raw-pending-check.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/on-task-complete.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/auto-checkpoint.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Agent"
    ]
  }
}
